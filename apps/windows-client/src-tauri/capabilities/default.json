{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Agent Cowork desktop shell permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/kimi-cowork-host",
          "sidecar": true
        }
      ]
    }
  ]
}
