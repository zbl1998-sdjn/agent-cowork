{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Cowork",
  "version": "0.2.0",
  "identifier": "com.agent.cowork",
  "build": {
    "beforeDevCommand": "node ../../../scripts/start-tauri-dev.mjs",
    "beforeBuildCommand": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../../scripts/prepare-embedded-python.ps1",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui-dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3017 http://127.0.0.1:5173 ws://127.0.0.1:5173; img-src 'self' data:; object-src 'none'; frame-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent Cowork",
        "width": 1366,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "useLocalToolsDir": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/python-embedded": "python-embedded"
    },
    "externalBin": [
      "binaries/agent-cowork-host"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFRjEyMzhFM0IwODI5ODcKUldTSEtRZzdqaVB4UHZGbFRVTm5zVUFVQ3RCeXdUUlhLNkR2OXBtQlFTTTF3UEw1bXd6b1huR0MK",
      "endpoints": [
        "https://updates.agent-cowork.local/desktop-update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
