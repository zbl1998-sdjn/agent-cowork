{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Cowork",
  "version": "0.1.0",
  "identifier": "com.agent.cowork",
  "build": {
    "beforeDevCommand": "node ../../../scripts/start-tauri-dev.mjs",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui-dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3017 http://127.0.0.1:5173 ws://127.0.0.1:5173; img-src 'self' data:; object-src 'none'; frame-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent Cowork",
        "width": 1366,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/agent-cowork-host"
    ]
  }
}
