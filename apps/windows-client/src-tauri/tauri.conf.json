{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kimi Cowork",
  "version": "0.1.0",
  "identifier": "com.kimi.cowork",
  "build": {
    "beforeDevCommand": "node ../../../scripts/start-tauri-host.mjs",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:3017",
    "frontendDist": "../resources"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3017; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Kimi Cowork",
        "width": 1366,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": ["binaries/kimi-cowork-host"],
    "resources": ["../resources"]
  }
}
