{
  "name": "kimi-cowork-host-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Kimi-only local cowork host MVP scaffold",
  "scripts": {
    "start": "node apps/host/src/main.js",
    "start:mvp": "node scripts/start-mvp.mjs",
    "status:mvp": "node scripts/status-mvp.mjs",
    "stop:mvp": "node scripts/stop-mvp.mjs",
    "demo:mvp": "node scripts/demo-mvp.mjs",
    "start:tauri-host": "node scripts/start-tauri-host.mjs",
    "audit:mvp": "node scripts/audit-mvp.mjs",
    "verify:mvp": "node scripts/verify-mvp.mjs",
    "verify:windows-readiness": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-windows-client-readiness.ps1",
    "smoke:host": "node scripts/smoke-local-operations.mjs",
    "smoke:live-mvp": "node scripts/smoke-live-mvp.mjs",
    "smoke:mvp-runtime": "node scripts/smoke-mvp-runtime.mjs",
    "smoke:kimi-api": "node scripts/smoke-kimi-api.mjs",
    "smoke:tauri-scaffold": "node scripts/smoke-tauri-scaffold.mjs",
    "smoke:rendered-ui": "node scripts/smoke-rendered-ui.mjs",
    "smoke:windows-resources": "node scripts/smoke-windows-client-resources.mjs",
    "smoke:ui": "node scripts/smoke-ui-contract.mjs",
    "test": "npm run test:host && npm run test:ui",
    "test:isolated": "cd apps/host && node --test",
    "build:ui": "node scripts/build-ui.mjs",
    "build:ui:fresh": "node scripts/build-ui.mjs --install",
    "test:host": "cd apps/host && node --test --test-isolation=process --test-timeout=60000 --import ../../test-setup.mjs \"test/*.test.js\"",
    "test:ui": "npm --prefix apps/windows-client/ui run test"
  },
  "engines": {
    "node": ">=20"
  }
}
