{
  "name": "agent-cowork-host-mvp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Kimi-only local cowork host MVP scaffold",
  "scripts": {
    "start": "node apps/host/src/main.js",
    "start:mvp": "node scripts/start-mvp.mjs",
    "status:mvp": "node scripts/status-mvp.mjs",
    "stop:mvp": "node scripts/stop-mvp.mjs",
    "demo:mvp": "node scripts/demo-mvp.mjs",
    "start:tauri-host": "node scripts/start-tauri-host.mjs",
    "audit:mvp": "node scripts/audit-mvp.mjs",
    "verify:mvp": "node scripts/verify-mvp.mjs",
    "verify:windows-readiness": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-windows-client-readiness.ps1",
    "smoke:host": "node scripts/smoke-local-operations.mjs",
    "smoke:live-mvp": "node scripts/smoke-live-mvp.mjs",
    "smoke:plan-loop": "node scripts/smoke-plan-closed-loop.mjs",
    "smoke:mvp-runtime": "node scripts/smoke-mvp-runtime.mjs",
    "smoke:kimi-api": "node scripts/smoke-kimi-api.mjs",
    "smoke:tauri-scaffold": "node scripts/smoke-tauri-scaffold.mjs",
    "smoke:rendered-ui": "node scripts/smoke-rendered-ui.mjs",
    "smoke:react-scroll": "node scripts/smoke-react-scroll.mjs",
    "smoke:react-artifacts": "node scripts/smoke-react-artifacts-panel.mjs",
    "smoke:react-live-artifact": "node scripts/smoke-react-live-artifact.mjs",
    "smoke:react-branches": "node scripts/smoke-react-branches.mjs",
    "smoke:react-connectors": "node scripts/smoke-react-connectors.mjs",
    "smoke:windows-resources": "node scripts/smoke-windows-client-resources.mjs",
    "smoke:e2e": "node scripts/e2e-smoke.mjs",
    "bench": "node scripts/bench.mjs",
    "smoke:windows-client": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-windows-client.ps1",
    "smoke:installed-tauri": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-installed-tauri.ps1",
    "smoke:ui": "node scripts/smoke-ui-contract.mjs",
    "check:arch": "node scripts/check-arch.mjs",
    "check:filesize": "node scripts/check-filesize.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:host-types": "node scripts/check-host-types.mjs",
    "check": "npm run check:arch && npm run check:filesize && npm run check:secrets && npm run check:host-types",
    "ci": "node scripts/ci.mjs",
    "release": "node scripts/release.mjs",
    "test": "npm run test:host && npm run test:ui",
    "test:isolated": "cd apps/host && node --test",
    "build:ui": "node scripts/build-ui.mjs",
    "build:ui:fresh": "node scripts/build-ui.mjs --install",
    "test:host": "npm run check && cd apps/host && node --test --test-isolation=process --test-timeout=60000 --import ../../test-setup.mjs \"test/*.test.js\"",
    "test:ui": "npm --prefix apps/windows-client/ui run test"
  },
  "engines": {
    "node": ">=20"
  }
}
