# Kimi Cowork host configuration.
# Copy this file to `.env` (which is gitignored) and fill in your values.
# You can also set the API key in-app: Settings -> API.

# --- Kimi / Moonshot API ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-0905-preview

# --- Host ---
# The desktop app talks to the host on 3017.
PORT=3017

# --- Security (keep these ON for anything beyond a single local machine) ---
# Require a valid token on every /api route (default: on).
KCW_REQUIRE_AUTH=true
# Trust x-tenant-id/x-user-id headers (ONLY behind a trusted reverse proxy).
KCW_TRUST_IDENTITY_HEADERS=false
# Stateless JWT secret (leave empty to use local opaque sessions).
KCW_JWT_SECRET=

# --- Storage backend: file | sqlite | postgres ---
KCW_STORE=file
# DATABASE_URL=postgres://user:pass@host:5432/db   # required when KCW_STORE=postgres

# --- Optional tuning ---
# KCW_RATE_PER_SEC=50
# KCW_RATE_BURST=100
# KCW_LOG_MAX_BYTES=8388608
# KCW_LOG_MAX_FILES=3

# --- Optional GitHub connector OAuth device flow ---
# Create a GitHub OAuth App with device flow enabled, then set the public client id.
# No client secret is accepted or needed by this connector.
# KCW_GITHUB_OAUTH_CLIENT_ID=
