node_modules/
build/
dist/
coverage/
.KimiCowork/
.AgentCowork/
.eval/
*.log
*.log.err

# secrets
.env
.env.local

# --- build artifacts / release outputs (added for release hygiene) ---
apps/windows-client/src-tauri/target/
apps/windows-client/ui-dist/
apps/host/dist/
installers/
*.fuse_hidden*
# tsc -b emits .js next to the .ts sources (these shadow the .ts in vite/vitest);
# they are build artifacts, regenerated by `npm run build` / `test:ui`.
apps/windows-client/ui/src/**/*.js
apps/windows-client/ui/src/**/*.js.map
apps/windows-client/ui/*.tsbuildinfo

# Node SEA sidecar binary (91MB build artifact, regenerated by the SEA build).
# Keep the README/manifest in binaries/, just not the compiled exe.
apps/windows-client/src-tauri/binaries/*.exe

# Embedded Python is staged from the pinned official package during Tauri builds.
# Keep the instructions tracked, not the generated runtime payload.
apps/windows-client/resources/python-embedded/*
!apps/windows-client/resources/python-embedded/README.md

# Local runtime state / scratch (never part of the release baseline).
*.sqlite
*.sqlite-wal
*.sqlite-shm
hosttest*.done
*.done
# Agent demo / scratch outputs produced during manual testing.
agent-demo*.md
approval-demo.txt
risk-demo.txt
reports/eval/
